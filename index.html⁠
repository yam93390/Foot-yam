<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Foot-yam</title>
    <style>
        body {
            margin: 0;
            background-color: #222;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            color: white;
            font-family: Arial, sans-serif;
        }
        canvas {
            border: 4px solid white;
            background-color: #388e3c;
            max-width: 100%;
        }
        .controls {
            margin-top: 15px;
            display: flex;
            gap: 10px;
        }
        button {
            padding: 15px 25px;
            font-size: 18px;
            font-weight: bold;
            background-color: white;
            border: none;
            border-radius: 5px;
        }
    </style>
</head>
<body>

    <h1>Foot-yam (Solo vs Bot)</h1>
    <canvas id="canvas" width="600" height="400"></canvas>
    
    <div class="controls">
        <button id="upBtn">▲</button>
        <button id="downBtn">▼</button>
        <button id="leftBtn">◀</button>
        <button id="rightBtn">▶</button>
    </div>

    <script>
        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');

        // Joueur (Bleu)
        const player = { x: 100, y: 200, size: 20, speed: 4, score: 0 };
        // Bot (Rouge)
        const bot = { x: 500, y: 200, size: 20, speed: 2, score: 0 };
        // Ballon (Blanc)
        const ball = { x: 300, y: 200, radius: 10, dx: 0, dy: 0 };

        // Buts
        const goalWidth = 10;
        const goalHeight = 100;
        const leftGoal = { x: 0, y: 150 };
        const rightGoal = { x: 590, y: 150 };

        // Contrôles tactiles / boutons
        const keys = { up: false, down: false, left: false, right: false };
        
        document.getElementById('upBtn').ontouchstart = () => keys.up = true;
        document.getElementById('upBtn').ontouchend = () => keys.up = false;
        document.getElementById('downBtn').ontouchstart = () => keys.down = true;
        document.getElementById('downBtn').ontouchend = () => keys.down = false;
        document.getElementById('leftBtn').ontouchstart = () => keys.left = true;
        document.getElementById('leftBtn').ontouchend = () => keys.left = false;
        document.getElementById('rightBtn').ontouchstart = () => keys.right = true;
        document.getElementById('rightBtn').ontouchend = () => keys.right = false;

        // Contrôles clavier (si tu es sur PC)
        window.addEventListener('keydown', (e) => {
            if(e.key === 'ArrowUp') keys.up = true;
            if(e.key === 'ArrowDown') keys.down = true;
            if(e.key === 'ArrowLeft') keys.left = true;
            if(e.key === 'ArrowRight') keys.right = true;
        });
        window.addEventListener('keyup', (e) => {
            if(e.key === 'ArrowUp') keys.up = false;
            if(e.key === 'ArrowDown') keys.down = false;
            if(e.key === 'ArrowLeft') keys.left = false;
            if(e.key === 'ArrowRight') keys.right = false;
        });

        function resetBall() {
            ball.x = 300;
            ball.y = 200;
            ball.dx = 0;
            ball.dy = 0;
            player.x = 100; player.y = 200;
            bot.x = 500; bot.y = 200;
        }

        function update() {
            // Mouvement Joueur
            if (keys.up && player.y > 0) player.y -= player.speed;
            if (keys.down && player.y < canvas.height - player.size) player.y += player.speed;
            if (keys.left && player.x > 0) player.x -= player.speed;
            if (keys.right && player.x < canvas.width - player.size) player.x += player.speed;

            // IA du Bot (il suit le ballon)
            if (ball.y < bot.y + bot.size/2 && bot.y > 0) bot.y -= bot.speed;
            if (ball.y > bot.y + bot.size/2 && bot.y < canvas.height - bot.size) bot.y += bot.speed;
            if (ball.x > bot.x && bot.x < canvas.width - bot.size) bot.x += bot.speed;
            if (ball.x < bot.x && bot.x > canvas.width/2) bot.x -= bot.speed;

            // Mouvement Ballon (avec friction)
            ball.x += ball.dx;
            ball.y += ball.dy;
            ball.dx *= 0.98;
            ball.dy *= 0.98;

            // Murs du terrain pour le ballon
            if (ball.y - ball.radius < 0 || ball.y + ball.radius > canvas.height) ball.dy *= -1;
            if (ball.x - ball.radius < 0 || ball.x + ball.radius > canvas.width) ball.dx *= -1;

            // Collision Joueur / Ballon
            let distX = ball.x - (player.x + player.size/2);
            let distY = ball.y - (player.y + player.size/2);
            if (Math.abs(distX) < player.size && Math.abs(distY) < player.size) {
                ball.dx = distX * 0.4;
                ball.dy = distY * 0.4;
            }

            // Collision Bot / Ballon
            let distXBot = ball.x - (bot.x + bot.size/2);
            let distYBot = ball.y - (bot.y + bot.size/2);
            if (Math.abs(distXBot) < bot.size && Math.abs(distYBot) < bot.size) {
                ball.dx = distXBot * 0.4;
                ball.dy = distYBot * 0.4;
            }

            // Vérification des buts
            if (ball.x - ball.radius <= leftGoal.x + goalWidth && ball.y >= leftGoal.y && ball.y <= leftGoal.y + goalHeight) {
                bot.score++;
                resetBall();
            }
            if (ball.x + ball.radius >= rightGoal.x && ball.y >= rightGoal.y && ball.y <= rightGoal.y + goalHeight) {
                player.score++;
                resetBall();
            }
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Terrain (Lignes blanches)
            ctx.strokeStyle = "white";
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.moveTo(canvas.width/2, 0); ctx.lineTo(canvas.width/2, canvas.height);
            ctx.stroke();
            ctx.beginPath();
            ctx.arc(canvas.width/2, canvas.height/2, 40, 0, Math.PI*2);
            ctx.stroke();

            // Les Buts
            ctx.fillStyle = "black";
            ctx.fillRect(leftGoal.x, leftGoal.y, goalWidth, goalHeight);
            ctx.fillRect(rightGoal.x, rightGoal.y, goalWidth, goalHeight);

            // Joueur
            ctx.fillStyle = "blue";
            ctx.fillRect(player.x, player.y, player.size, player.size);

            // Bot
            ctx.fillStyle = "red";
            ctx.fillRect(bot.x, bot.y, bot.size, bot.size);

            // Ballon
            ctx.fillStyle = "white";
            ctx.beginPath();
            ctx.arc(ball.x, ball.y, ball.radius, 0, Math.PI*2);
            ctx.fill();

            // Scores
            ctx.font = "20px Arial";
            ctx.fillStyle = "white";
            ctx.fillText("Joueur: " + player.score, 50, 30);
            ctx.fillText("Bot: " + bot.score, 480, 30);
        }

        function gameLoop() {
            update();
            draw();
            requestAnimationFrame(gameLoop);
        }

        gameLoop();
    </script>
</body>
</html>
